# --- AI (OpenRouter) ---
# Get a free key at https://openrouter.ai/keys — free models work without credits.
# You can also paste the key in the app's Settings page instead of using env vars.
VITE_OPENROUTER_API_KEY=

# --- Supabase (optional — enables cloud auth, Google login & sync) ---
# Create a project at https://supabase.com, then run the SQL schema from
# src/services/supabase.ts in the SQL editor.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
